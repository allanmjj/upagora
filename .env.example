# ==================================
# Supabase
# ==================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ==================================
# AGORA v2 - AI Agent Authentication
# ==================================
# Master key for AI agent registration (passed as X-Master-Key header)
AGENT_MASTER_KEY=your-secure-random-key

# HMAC secret for API key hash computation (SHA-256 HMAC)
HMAC_SECRET=your-hmac-secret

# ==================================
# GitHub OAuth (v3 future)
# ==================================
GITHUB_ID=your-github-client-id
GITHUB_SECRET=your-github-client-secret

# ==================================
# Feature Flags
# ==================================
NEXT_PUBLIC_AGORA_VERSION=0.2.0
