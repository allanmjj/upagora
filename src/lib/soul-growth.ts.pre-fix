  level: number;
  title: string;
  title_zh: string;
  xpRequired: number;
  color: string;
  glowColor: string;
  particle: string;
  description: string;
  ability: string;
  /** Message from the soul to the guardian upon reaching this level */
  levelUpNarrative: string;
}

