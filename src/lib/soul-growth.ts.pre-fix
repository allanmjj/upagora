/**
 * Check which milestones a soul has achieved.
 */
export function getAchievedMilestones(growth: SoulGrowth, stats: any): SoulMilestone[] {
  return SOUL_MILESTONES.filter(m => m.condition(growth, stats));
}

/**
 * Check which milestones are next (one condition away).
 */
export function getNextMilestones(growth: SoulGrowth, stats: any): SoulMilestone[] {
  return SOUL_MILESTONES.filter(m => !m.condition(growth, stats));
}

/**
 * Narrative milestone event — represents a milestone just achieved,
 * with the soul's narrative message ready for display/notification.
 */
export interface MilestoneEvent {
  milestoneId: string;
  milestone: SoulMilestone;
  narrative: string;
  emotion: "warm" | "proud" | "contemplative" | "joyful" | "bittersweet" | "awe";
  level?: number;
  isLevelUp: boolean;
  /** Timestamp of when this was detected */
  detectedAt: string;
}

/**
 * Detect NEW milestones just achieved by comparing previous state with current state.
 * Core function for the narrative milestone system — tells us "what just happened".
 */
export function detectNewMilestones(
  previousLevel: number,
  previousStats: { conversations?: number; discoveries?: number; daysActive?: number },
  growth: SoulGrowth,
  currentStats: { conversations?: number; discoveries?: number; daysActive?: number }
): MilestoneEvent[] {
  const previousGrowth: SoulGrowth = {
    level: previousLevel,
    xp: 0,
    xpToNext: 0,
    progressPercent: 0,
    levelInfo: SOUL_LEVELS.find(l => l.level === previousLevel) || SOUL_LEVELS[0],
    unlockedTraits: [],
    isMaxLevel: previousLevel >= SOUL_LEVELS.length,
  };

  const newEvents: MilestoneEvent[] = [];

  // Check for level-up transition
  if (growth.level > previousLevel) {
    const levelInfo = SOUL_LEVELS.find(l => l.level === growth.level);
    if (levelInfo && levelInfo.levelUpNarrative) {
      newEvents.push({
        milestoneId: `level_up_${growth.level}`,
        milestone: {
          id: `level_up_${growth.level}`,
          title: `Level ${growth.level}: ${levelInfo.title}`,
          icon: levelInfo.particle,
          condition: () => false,
          description: levelInfo.description,
          narrative: levelInfo.levelUpNarrative,
          emotion: "joyful",
        },
        narrative: levelInfo.levelUpNarrative,
        emotion: "joyful",
        level: growth.level,
        isLevelUp: true,
        detectedAt: new Date().toISOString(),
      });
    }
  }

  // Check for newly achieved standard milestones
  for (const milestone of SOUL_MILESTONES) {
    const wasAchieved = milestone.condition(previousGrowth, previousStats);
    const isAchieved = milestone.condition(growth, currentStats);

    if (!wasAchieved && isAchieved) {
      newEvents.push({
        milestoneId: milestone.id,
        milestone,
        narrative: milestone.narrative,
        emotion: milestone.emotion,
        level: growth.level,
        isLevelUp: false,
        detectedAt: new Date().toISOString(),
      });
    }
  }

  return newEvents;
}

/**
 * Generate a narrative summary for a level-up, personalized with the soul's name.
 * Used for notifications and share cards.
 */
export function generateLevelUpNarrative(
  soulName: string,
  fromLevel: number,
  toLevel: number
): string {
  const levelInfo = SOUL_LEVELS.find(l => l.level === toLevel);
  if (!levelInfo) return `${soulName} has reached level ${toLevel}!`;
  return `${soulName}: "${levelInfo.levelUpNarrative}"`;
}
