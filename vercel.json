{
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "outputDirectory": ".next",
  "regions": ["sin1"],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ],
  "env": {
    "NEXT_PUBLIC_AGORA_VERSION": "0.1.0",
    "NEXT_TURBOPACK": "0"
  },
  "buildCommand": "NEXT_TURBOPACK=0 next build"
}
